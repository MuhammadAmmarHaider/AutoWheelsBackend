// Used Cars Marketplace - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Role {
  USER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum ListingStatus {
  ACTIVE
  SOLD
  PENDING
}

enum DrivetrainType {
  FWD
  RWD
  AWD
  FOURWD
}

//////////////////////////////////////
// USER
//////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  location    String?
  birthday    DateTime?
  gender      String?
  cityId      String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city             City?     @relation(fields: [cityId], references: [id])
  listings         Listing[]
  favorites        Favorite[]
  sentMessages     Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")
  reviews          Review[]
}

//////////////////////////////////////
// CITY
//////////////////////////////////////

model City {
  id   String @id @default(uuid())
  name String @unique

  users              User[]
  listings           Listing[]  @relation("ListingCity")
  registeredListings Listing[]  @relation("RegisteredCity")

  @@index([name])
}

//////////////////////////////////////
// BRAND & MODEL
//////////////////////////////////////

model Brand {
  id      String @id @default(uuid())
  name    String @unique
  country String?

  models   CarModel[]
  listings Listing[]
  newCars  NewCar[]

  @@index([name])
}

model CarModel {
  id      String @id @default(uuid())
  name    String
  brandId String

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  listings Listing[]
  newCars  NewCar[]

  @@unique([name, brandId])
  @@index([brandId])
}

//////////////////////////////////////
// NEW CAR (SHOWROOM CATALOG)
//////////////////////////////////////

model NewCar {
  id          String   @id @default(uuid())
  brandId     String
  modelId     String
  name        String
  year        Int
  priceMin    Float
  priceMax    Float?
  bodyType    String?
  engine      String?
  horsepower  Int?
  torque      String?
  fuelType    FuelType
  transmission Transmission
  mileage     String?       // e.g. "90 km EV + 1000km+ total"
  seating     Int?
  topSpeed    Int?
  safetyRating Float?
  airbags     Int?
  infotainment String?
  features    String[]      // Postgres text array
  description String
  launchDate  DateTime?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model       CarModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  dimensions        CarDimensions?
  engineDetails     CarEngineDetails?
  transmissionDetails CarTransmissionDetails?
  steering          CarSteering?
  suspension        CarSuspension?
  wheels            CarWheels?
  fuelEconomy       CarFuelEconomy?
  images            NewCarImage[]
  reviews           Review[]

  @@unique([name, year, brandId])
  @@index([brandId])
  @@index([modelId])
  @@index([featured])
  @@index([fuelType])
  @@index([bodyType])
  @@index([year])
}

//////////////////////////////////////
// NEW CAR — SPEC SUB-TABLES
//////////////////////////////////////

model CarDimensions {
  id              String @id @default(uuid())
  newCarId        String @unique
  length          Int?          // mm
  width           Int?          // mm
  height          Int?          // mm
  wheelbase       Int?          // mm
  groundClearance Int?          // mm
  bootSpace       Int?          // liters
  doors           Int?
  seating         Int?

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarEngineDetails {
  id             String  @id @default(uuid())
  newCarId       String  @unique
  type           String?
  turbocharged   Boolean @default(false)
  displacement   Int?           // cc
  cylinders      Int?
  drivetrain     DrivetrainType?
  fuelSystem     String?
  valveMechanism String?
  maxSpeed       Int?           // km/h

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarTransmissionDetails {
  id       String @id @default(uuid())
  newCarId String @unique
  type     String?
  gearbox  String?

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarSteering {
  id             String  @id @default(uuid())
  newCarId       String  @unique
  type           String?
  turningRadius  Float?
  powerAssisted  Boolean @default(false)

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarSuspension {
  id          String @id @default(uuid())
  newCarId    String @unique
  front       String?
  frontBrakes String?
  rear        String?
  rearBrakes  String?

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarWheels {
  id          String @id @default(uuid())
  newCarId    String @unique
  wheelType   String?
  tyreSize    String?
  wheelSize   String?
  pcd         String?
  spareTyreSize String?

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model CarFuelEconomy {
  id               String @id @default(uuid())
  newCarId         String @unique
  cityMileage      Float?
  highwayMileage   Float?
  tankCapacity     Float?

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)
}

model NewCarImage {
  id       String @id @default(uuid())
  url      String
  newCarId String

  newCar NewCar @relation(fields: [newCarId], references: [id], onDelete: Cascade)

  @@index([newCarId])
}

//////////////////////////////////////
// LISTING (USED CARS)
//////////////////////////////////////

model Listing {
  id               String        @id @default(uuid())
  title            String
  description      String
  price            Float
  year             Int
  mileage          Int
  bodyColor        String?
  contactName      String?
  contactPhone     String?
  allowWhatsapp    Boolean       @default(false)
  fuelType         FuelType
  transmission     Transmission
  status           ListingStatus @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  userId           String
  brandId          String
  modelId          String
  cityId           String
  registeredCityId String?

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model          CarModel @relation(fields: [modelId], references: [id], onDelete: Restrict)
  city           City     @relation("ListingCity", fields: [cityId], references: [id], onDelete: Restrict)
  registeredCity City?    @relation("RegisteredCity", fields: [registeredCityId], references: [id], onDelete: SetNull)

  images    Image[]
  favorites Favorite[]
  messages  Message[]

  @@index([userId])
  @@index([status])
  @@index([cityId])
  @@index([registeredCityId])
  @@index([brandId])
  @@index([modelId])
}

//////////////////////////////////////
// IMAGES
//////////////////////////////////////

model Image {
  id        String @id @default(uuid())
  url       String
  listingId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

//////////////////////////////////////
// FAVORITES
//////////////////////////////////////

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

//////////////////////////////////////
// REVIEWS (FOR NEW CARS)
//////////////////////////////////////

model Review {
  id                    String   @id @default(uuid())
  title                 String
  description           String
  styleRating           Int      // 1-5
  comfortRating         Int      // 1-5
  fuelEconomyRating     Int      // 1-5
  performanceRating     Int      // 1-5
  valueForMoneyRating   Int      // 1-5
  overallRating         Float    // Calculated: average of 5 categories
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId                String
  newCarId              String

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newCar                NewCar   @relation(fields: [newCarId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([newCarId])
  @@index([createdAt])
}

//////////////////////////////////////
// CHAT SYSTEM
//////////////////////////////////////

model Message {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())

  senderId   String
  receiverId String
  listingId  String

  sender   User    @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User    @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([listingId])
}