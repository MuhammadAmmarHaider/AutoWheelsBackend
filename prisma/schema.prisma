// Used Cars Marketplace - Prisma Schema
// A platform for buying and selling used cars with messaging and favorites

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////
// ENUMS
//////////////////////////////////////

enum Role {
  USER
  ADMIN
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum ListingStatus {
  ACTIVE
  SOLD
  PENDING
}

//////////////////////////////////////
// USER
//////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  cityId      String?
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  city              City?         @relation(fields: [cityId], references: [id])
  listings          Listing[]
  favorites         Favorite[]
  sentMessages      Message[]     @relation("Sender")
  receivedMessages  Message[]     @relation("Receiver")
}

//////////////////////////////////////
// CITY
//////////////////////////////////////

model City {
  id        String @id @default(uuid())
  name      String @unique

  users     User[]
  listings  Listing[] @relation("ListingCity")
  registeredListings Listing[] @relation("RegisteredCity")

  @@index([name])
}

//////////////////////////////////////
// BRAND & MODEL
//////////////////////////////////////

model Brand {
  id     String     @id @default(uuid())
  name   String     @unique

  models    CarModel[]
  listings  Listing[]

  @@index([name])
}

model CarModel {
  id      String @id @default(uuid())
  name    String
  brandId String

  brand   Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([name, brandId]) // Each brand can have only one model with the same name
  @@index([brandId])
}

//////////////////////////////////////
// LISTING (MAIN ENTITY)
//////////////////////////////////////

model Listing {
  id            String   @id @default(uuid())
  title         String
  description   String
  price         Float
  year          Int
  mileage       Int
  bodyColor     String?
  contactName   String?
  contactPhone  String?
  allowWhatsapp Boolean  @default(false)
  fuelType      FuelType
  transmission  Transmission
  status        ListingStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  brandId       String
  modelId       String
  cityId        String
  registeredCityId String?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand         Brand     @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model         CarModel  @relation(fields: [modelId], references: [id], onDelete: Restrict)
  city          City      @relation("ListingCity", fields: [cityId], references: [id], onDelete: Restrict)
  registeredCity City?    @relation("RegisteredCity", fields: [registeredCityId], references: [id], onDelete: SetNull)

  images        Image[]
  favorites     Favorite[]
  messages      Message[]

  @@index([userId])
  @@index([status])
  @@index([cityId])
  @@index([registeredCityId])
}

//////////////////////////////////////
// IMAGES
//////////////////////////////////////

model Image {
  id         String @id @default(uuid())
  url        String
  listingId  String

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

//////////////////////////////////////
// FAVORITES (Wishlist)
//////////////////////////////////////

model Favorite {
  id        String @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId]) // prevent duplicates
  @@index([userId])
}

//////////////////////////////////////
// CHAT SYSTEM
//////////////////////////////////////

model Message {
  id          String   @id @default(uuid())
  content     String
  createdAt   DateTime @default(now())

  senderId    String
  receiverId  String
  listingId   String

  sender      User    @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User    @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([listingId])
}
